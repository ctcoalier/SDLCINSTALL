{
  "schema_version": 2,
  "version": "0.0.1",
  "monorepo": false,
  "package_manager": "pnpm",
  "commands": {
    "validate": {
      "exec": "node scripts/validate.js"
    },
    "view_pr": {
      "exec": "gh pr view feat/spec-driven-coding --repo ctcoalier/SDLCINSTALL --json url -q .url"
    }
  },
  "patterns": {
    "main_branch": "main"
  },
  "prd_dir": "docs/product",
  "roadmap_path": "docs/product/ccug-website/roadmap.md"
}
